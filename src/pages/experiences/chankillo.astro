---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";


import chankillo1 from '../../assets/chankillo-patrimonio-mundial.jpg'
import chankillo2 from '../../assets/Chanquillo_Fortaleza_(remains).jpg'
import chankillo3 from '../../assets/chankillo.jpg'
import chankillo4 from '../../assets/Las_trece_torres_del_observatorio_astronomico_de_Chanquillo.jpg'

---

<Layout title="Actividades Cercanas">
    <div class="container pt-15">
        <div class="mb-8 text-center">
            <h1 class="text-400 font-600 mb-4">Chankillo</h1>
            <p class="text-muted-foreground">Descubre todo lo que puedes hacer cerca de nuestro hotel</p>
        </div>

        <div class="mb-12">
            <div>
                <Image 
                    id="mainImage"
                    class="h-125 object-cover w-full cursor-zoom-in" 
                    src= {chankillo1}
                    alt="Actividad principal"
                />
            </div>
            
            <div class="mt-4 flex items-center justify-center gap-0.5 overflow-x-auto pb-2">
                <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index="main">
                    <Image 
                        class="h-full w-full object-cover" 
                        src= {chankillo1}
                        alt="Actividad principal"
                    />
                </div>
                <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index="0">
                    <Image 
                        class="h-full w-full object-cover" 
                        src= {chankillo2}
                        alt="Actividad 1"
                    />
                </div>
                <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index="1">
                    <Image 
                        class="h-full w-full object-cover" 
                        src= {chankillo3}
                        alt="Actividad 2"
                    />
                </div>
                <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index="2">
                    <Image 
                        class="h-full w-full object-cover" 
                        src= {chankillo4}
                        alt="Actividad 3"
                    />
                </div>

            </div>
        </div>

        <div class="mt-16 max-w-4xl mx-auto">
            <div class="mb-8">
                <h3 class="text-300 font-600 mb-4">Explora la Zona</h3>
                <p>
                    A pocos kilómetros de nuestro hotel, en el valle de Casma, se encuentra uno de los lugares arqueológicos más sorprendentes del Perú: Chankillo, un antiguo observatorio solar con más de 2200 años de antigüedad. Construido por la cultura Casma/Sechín, este complejo es considerado el observatorio solar más antiguo de América. En 2021 fue reconocido como Patrimonio Cultural de la Humanidad por la UNESCO, lo que confirma su enorme valor histórico y científico. Visitar Chankillo es viajar a una época en la que los antiguos peruanos ya observaban y estudiaban cuidadosamente el movimiento del Sol para comprender el paso del tiempo y los ciclos de la naturaleza.
                </p>
            </div>

            <div class="mb-8">
                <h3 class="text-300 font-600 mb-4">Actividades Populares</h3>
                <p>
                    El elemento más impresionante del sitio son las famosas Trece Torres, alineadas sobre una colina de norte a sur. Estas estructuras de piedra y barro, que alcanzan entre 2 y 6 metros de altura, forman una especie de calendario gigante en el horizonte. Desde puntos de observación específicos, los antiguos habitantes podían ver cómo el Sol salía entre las torres en diferentes momentos del año. Por ejemplo, durante el solsticio de diciembre, el Sol aparece alineado con la torre número 13, mientras que en el solsticio de junio sale al extremo opuesto del conjunto. Gracias a este ingenioso sistema, era posible seguir con gran precisión el movimiento anual del Sol.
                </p>
            </div>

            <div class="mb-8">
                <h3 class="text-300 font-600 mb-4">Recomendaciones Locales</h3>
                <p>
                    Además de las torres, el complejo incluye una fortaleza ubicada en la cima de una colina, plazas ceremoniales y estructuras administrativas que revelan que Chankillo fue también un importante centro social y ritual. Todo el conjunto demuestra el avanzado conocimiento astronómico de las antiguas culturas peruanas, quienes utilizaban estas observaciones para organizar actividades agrícolas, ceremonias y la vida cotidiana. Hoy, recorrer Chankillo permite contemplar no solo un paisaje impresionante del desierto costero de Áncash, sino también uno de los logros científicos más fascinantes del mundo antiguo.
                </p>
            </div>
        </div>
    </div>

    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Visor de imagen">
        <button id="lightbox-close" class="lightbox-close" aria-label="Cerrar">&#x2715;</button>
        <button id="lightbox-prev" class="lightbox-arrow lightbox-arrow--left" aria-label="Imagen anterior">&#8592;</button>
        <div class="lightbox-img-wrapper">
            <img id="lightbox-img" src="" alt="Imagen ampliada" />
        </div>
        <button id="lightbox-next" class="lightbox-arrow lightbox-arrow--right" aria-label="Imagen siguiente">&#8594;</button>
        <div id="lightbox-counter" class="lightbox-counter"></div>
    </div>
</Layout>


<style>
    /* ── Lightbox overlay ── */
    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.92);
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.25s ease;
    }
    .lightbox.is-open {
        display: flex;
        opacity: 1;
    }

    /* ── Image wrapper ── */
    .lightbox-img-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: calc(100vw - 160px);
        max-height: calc(100vh - 80px);
    }
    .lightbox-img-wrapper img {
        max-width: 100%;
        max-height: calc(100vh - 80px);
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 8px 60px rgba(0,0,0,0.6);
        transition: opacity 0.2s ease;
    }
    .lightbox-img-wrapper img.is-loading {
        opacity: 0;
    }

    /* ── Close button ── */
    .lightbox-close {
        position: fixed;
        top: 20px;
        right: 24px;
        color: oklch(0.9521 0.0221 80.69);
        font-size: 1.25rem;
        width: 42px;
        height: 42px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
        z-index: 10001;
    }
    .lightbox-close:hover {
        background: rgba(255,255,255,0.25);
        transform: scale(1.1);
    }

    /* ── Arrow buttons ── */
    .lightbox-arrow {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        color: oklch(0.9521 0.0221 80.69);
        font-size: 1.5rem;
        width: 52px;
        height: 52px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
        z-index: 10001;
    }
    .lightbox-arrow:hover {
        background: rgba(255,255,255,0.25);
        transform: translateY(-50%) scale(1.1);
    }
    .lightbox-arrow--left  { left: 20px; }
    .lightbox-arrow--right { right: 20px; }

    /* ── Counter ── */
    .lightbox-counter {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.6);
        font-size: 0.875rem;
        letter-spacing: 0.05em;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mainImage   = document.getElementById('mainImage') as HTMLImageElement | null;
        const thumbnails  = document.querySelectorAll<HTMLElement>('.thumbnail-item');
        const lightbox    = document.getElementById('lightbox');
        const lbImg       = document.getElementById('lightbox-img') as HTMLImageElement | null;
        const lbClose     = document.getElementById('lightbox-close');
        const lbPrev      = document.getElementById('lightbox-prev');
        const lbNext      = document.getElementById('lightbox-next');
        const lbCounter   = document.getElementById('lightbox-counter');

        if (!mainImage || !lightbox || !lbImg) return;

        // ── Build image list from thumbnails ──────────────────────────
        const images: { src: string; alt: string }[] = [];
        thumbnails.forEach((thumb) => {
            const img = thumb.querySelector('img');
            if (img) images.push({ src: img.getAttribute('src') || '', alt: img.alt });
        });

        let currentIndex = 0;

        // ── Thumbnail click → update main image ───────────────────────
        thumbnails.forEach((thumb) => {
            thumb.addEventListener('click', () => {
                const idx = parseInt(thumb.getAttribute('data-index') || '0', 10);
                currentIndex = idx;
                thumbnails.forEach(t => t.classList.remove('border-foreground'));
                thumb.classList.add('border-foreground');
                if (mainImage && images[idx]) {
                    mainImage.setAttribute('src', images[idx].src);
                    mainImage.setAttribute('data-index', String(idx));
                }
            });
        });

        // ── Open lightbox ─────────────────────────────────────────────
        function openLightbox(index: number) {
            currentIndex = index;
            showImage(currentIndex);
            lightbox.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }

        // ── Close lightbox ────────────────────────────────────────────
        function closeLightbox() {
            lightbox.classList.remove('is-open');
            document.body.style.overflow = '';
        }

        // ── Show image by index ───────────────────────────────────────
        function showImage(index: number) {
            if (!images.length) return;
            const i = (index + images.length) % images.length;
            currentIndex = i;
            lbImg.classList.add('is-loading');
            lbImg.onload = () => lbImg.classList.remove('is-loading');
            lbImg.src = images[i].src;
            lbImg.alt = images[i].alt;
            if (lbCounter) lbCounter.textContent = `${i + 1} / ${images.length}`;
        }

        // ── Main image click → open at current index ──────────────────
        mainImage.addEventListener('click', () => {
            const idx = parseInt(mainImage.getAttribute('data-index') || '0', 10);
            openLightbox(idx);
        });

        // ── Controls ──────────────────────────────────────────────────
        lbClose?.addEventListener('click', closeLightbox);
        lbPrev?.addEventListener('click',  () => showImage(currentIndex - 1));
        lbNext?.addEventListener('click',  () => showImage(currentIndex + 1));

        // Click outside image closes lightbox
        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });

        // Keyboard support
        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('is-open')) return;
            if (e.key === 'Escape')      closeLightbox();
            if (e.key === 'ArrowLeft')   showImage(currentIndex - 1);
            if (e.key === 'ArrowRight')  showImage(currentIndex + 1);
        });
    });
</script>
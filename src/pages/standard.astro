---
import Layout from "@/layouts/Layout.astro";

import RoomListing from '@/components/RoomListing';
import { sanityClient } from "sanity:client";
import type { Room } from "sanity.types";
import { buildBreadcrumbSchema } from "@/lib/seo";

const rooms = await sanityClient.fetch<Room[]>(
    `*[_type == "room" && category == "standard" && isAvailable]
    {"slug": slug.current, name, description, category, capacity, image, price, discount, thumbnailImgs }`
)

const breadcrumbSchema = buildBreadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Bungalows', path: '/all' },
    { name: 'Standard', path: '/standard' },
]);
---

<Layout
    title="Bungalows Standard"
    description="Bungalows Standard de Hotel Las Aldas en Casma, Áncash: cómodos, acogedores y a pasos de la playa. La opción ideal para tu vacación en la costa peruana."
    schema={breadcrumbSchema}
>
    <div class="relative z-40 ">
        <div class="container flex items-start justify-center flex-col h-[20]">
            <div class="z-40 max-w-175 mx-auto">
                <h1 class="mt-8 text-600 font-700 leading-[1.2] md:text-800">Bungalows Standard</h1>
            </div>
        </div>
    </div>

    </div>
    <div class="container pt-14">
        <div class="md:grid md:gap-9 md:grid-cols-2 lg:grid-cols-3">
            {rooms.map(room => (
                <RoomListing room={room} />
            ))}
        </div>
    </div>
</Layout>
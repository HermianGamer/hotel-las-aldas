---
import Layout from "@/layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import type { Room } from "sanity.types";
import { BedDouble, BedSingle, Camera, DoorClosed, Sofa, SolarPanel, Utensils, Users } from "lucide-react";
import { TbGrill } from "react-icons/tb";
import { MdOutlineCountertops } from "react-icons/md";
import Reservation from "@/components/Reservation";
import { urlFor } from "@/lib/sanityImageUrl"; // ajusta si tu helper tiene otro path

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

const room = await sanityClient.fetch<Room>(
    `*[_type == "room" && slug.current == $slug][0]{
        _id,
        name,
        "slug": slug.current,
        category,
        capacity,
        description,
        price,
        discount,
        isAvailable,
        image,
        imageInterior,
        thumbnails,
        features,
        amenities,
    }`,
    { slug }
);

if (!room) {
    return Astro.redirect('/404');
}
---

<Layout
    title={`Bungalow ${room.name}`}
    description={room.description
        ? `${room.description.slice(0, 145)}${room.description.length > 145 ? '…' : ''} Reserva el bungalow ${room.name} en Hotel Las Aldas, frente al mar en Áncash, Perú.`
        : `Conoce el bungalow ${room.name} de Hotel Las Aldas, frente al mar en Casma, Áncash, Perú.`}
    image={room.imageInterior ? urlFor(room.imageInterior).width(1200).height(630).fit('crop').quality(75).auto('format').url() : undefined}
>
    <div class="container pt-15">
        <div class="mb-8 text-center">
            <h1 class="text-800 font-600 font-playwrite text-primary mb-8">{room.name}</h1>

            <div class="flex flex-wrap items-center justify-center gap-4">
                {room.features?.map((feature: any) => (
                    <div class="flex items-center justify-center gap-2">
                        {feature.icon === 'door-closed' && <DoorClosed className="text-foreground" />}
                        {feature.icon === 'bed-double' && <BedDouble className="text-foreground" />}
                        {feature.icon === 'bed-single' && <BedSingle className="text-foreground" />}
                        {feature.icon === 'camera' && <Camera className="text-foreground" />}
                        <p>{feature.name}: <span>{feature.value}</span></p>
                    </div>
                ))}

                {/* Aforo */}
                <div class="flex items-center justify-center gap-2">
                    <Users className="text-foreground" />
                    <p>Aforo: <span>{room.capacity}</span></p>
                </div>
            </div>
        </div>

        <!-- imágenes -->
        <div>
            <div>
                <img id="mainImage" class="h-125 object-cover w-full cursor-zoom-in"
                    src={urlFor(room.imageInterior).width(1600).quality(75).auto('format').url()}
                    alt={room.name ?? ''}
                    fetchpriority="high"
                />
            </div>

            {room.thumbnails && room.thumbnails.length > 0 && (
                <div class="mt-4 flex items-center justify-center gap-0.5 overflow-x-auto pb-2">
                    <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index="main">
                        <img class="h-full w-full object-cover"
                            src={urlFor(room.imageInterior).width(160).height(160).fit('crop').quality(60).auto('format').url()}
                            data-full={urlFor(room.imageInterior).width(1600).quality(75).auto('format').url()}
                            alt={`${room.name} - main`}
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    {room.thumbnails.map((thumbnail: any, index: number) => (
                        <div class="thumbnail-item size-20 cursor-pointer overflow-hidden border hover:border-foreground" data-index={index}>
                            <img class="h-full w-full object-cover"
                                src={urlFor(thumbnail).width(160).height(160).fit('crop').quality(60).auto('format').url()}
                                data-full={urlFor(thumbnail).width(1600).quality(75).auto('format').url()}
                                alt={`${room.name} - thumbnail ${index}`}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    ))}
                </div>
            )}
        </div>

        <div class="mt-16 md:grid md:grid-cols-2 md:gap-8">
            <div>
                <div class="mb-8">
                    <h3 class="text-300 font-600 mb-4">Descripción</h3>
                    <p class="text-justify">{room.description}</p>
                </div>

                <div>
                    <h3 class="text-300 font-600 mb-4">Amenidades</h3>
                    <div class="mb-8 grid grid-cols-2 gap-4">
                        {room.amenities?.map((amenity: any) => (
                            <div class="flex items-center gap-4">
                                {amenity.icon === 'cooking-pot' && <MdOutlineCountertops className="w-6 h-6 text-foreground" />}
                                {amenity.icon === 'solar-panel' && <SolarPanel className="text-foreground" />}
                                {amenity.icon === 'sofa' && <Sofa className="text-foreground" />}
                                {amenity.icon === 'utensils' && <Utensils className="text-foreground" />}
                                {amenity.icon === 'beef' && <TbGrill className="w-6 h-6 text-foreground" />}
                                <p>{amenity.name}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <p class="text-muted-foreground">
                    A pocos minutos de este bungalow: playas, arqueología y naturaleza. Descubre
                    <a href="/destinos" class="underline underline-offset-2 hover:text-primary">las playas y destinos cerca de Áncash</a>
                    o revisa nuestras <a href="/faq" class="underline underline-offset-2 hover:text-primary">preguntas frecuentes</a>
                    sobre check-in y reservas.
                </p>
            </div>

            <div>
                <Reservation room={room} client:load />
            </div>
        </div>
    </div>

    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Visor de imagen">
        <button id="lightbox-close" class="lightbox-close" aria-label="Cerrar">&#x2715;</button>
        <button id="lightbox-prev" class="lightbox-arrow lightbox-arrow--left" aria-label="Imagen anterior">&#8592;</button>
        <div class="lightbox-img-wrapper">
            <img id="lightbox-img" src="" alt="Imagen ampliada" />
        </div>
        <button id="lightbox-next" class="lightbox-arrow lightbox-arrow--right" aria-label="Imagen siguiente">&#8594;</button>
        <div id="lightbox-counter" class="lightbox-counter"></div>
    </div>
</Layout>

<style>
    /* ── Lightbox overlay ── */
    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.92);
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.25s ease;
    }
    .lightbox.is-open {
        display: flex;
        opacity: 1;
    }

    /* ── Image wrapper ── */
    .lightbox-img-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: calc(100vw - 160px);
        max-height: calc(100vh - 80px);
    }
    .lightbox-img-wrapper img {
        max-width: 100%;
        max-height: calc(100vh - 80px);
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 8px 60px rgba(0,0,0,0.6);
        transition: opacity 0.2s ease;
    }
    .lightbox-img-wrapper img.is-loading {
        opacity: 0;
    }

    /* ── Close button ── */
    .lightbox-close {
        position: fixed;
        top: 20px;
        right: 24px;
        color: oklch(0.9521 0.0221 80.69);
        font-size: 1.25rem;
        width: 42px;
        height: 42px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
        z-index: 10001;
    }
    .lightbox-close:hover {
        background: rgba(255,255,255,0.25);
        transform: scale(1.1);
    }

    /* ── Arrow buttons ── */
    .lightbox-arrow {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        color: oklch(0.9521 0.0221 80.69);
        font-size: 1.5rem;
        width: 52px;
        height: 52px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
        z-index: 10001;
    }
    .lightbox-arrow:hover {
        background: rgba(255,255,255,0.25);
        transform: translateY(-50%) scale(1.1);
    }
    .lightbox-arrow--left  { left: 20px; }
    .lightbox-arrow--right { right: 20px; }

    /* ── Counter ── */
    .lightbox-counter {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.6);
        font-size: 0.875rem;
        letter-spacing: 0.05em;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mainImage   = document.getElementById('mainImage') as HTMLImageElement | null;
        const thumbnails  = document.querySelectorAll<HTMLElement>('.thumbnail-item');
        const lightbox    = document.getElementById('lightbox');
        const lbImg       = document.getElementById('lightbox-img') as HTMLImageElement | null;
        const lbClose     = document.getElementById('lightbox-close');
        const lbPrev      = document.getElementById('lightbox-prev');
        const lbNext      = document.getElementById('lightbox-next');
        const lbCounter   = document.getElementById('lightbox-counter');

        if (!mainImage || !lightbox || !lbImg) return;

        // ── Build image list from thumbnails ──────────────────────────
        const images: { src: string; alt: string }[] = [];
        thumbnails.forEach((thumb) => {
            const img = thumb.querySelector('img');
            if (img) images.push({ src: img.getAttribute('data-full') || img.getAttribute('src') || '', alt: img.alt });
        });

        let currentIndex = 0;

        // ── Thumbnail click ────────────────────────────────────────────
        thumbnails.forEach((thumb, i) => {
        thumb.addEventListener('click', () => {
            currentIndex = i; // usa 'i' del forEach, no data-index
            if (mainImage) {
            mainImage.src = images[i].src;
            mainImage.alt = images[i].alt;
            }
        });
        });

        // ── Open lightbox ─────────────────────────────────────────────
        function openLightbox(index: number) {
            currentIndex = index;
            showImage(currentIndex);
            lightbox.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }

        // ── Close lightbox ────────────────────────────────────────────
        function closeLightbox() {
            lightbox.classList.remove('is-open');
            document.body.style.overflow = '';
        }

        // ── Show image by index ───────────────────────────────────────
        function showImage(index: number) {
            if (!images.length) return;
            const i = (index + images.length) % images.length;
            currentIndex = i;
            lbImg.classList.add('is-loading');
            lbImg.onload = () => lbImg.classList.remove('is-loading');
            lbImg.src = images[i].src;
            lbImg.alt = images[i].alt;
            if (lbCounter) lbCounter.textContent = `${i + 1} / ${images.length}`;
        }

        // ── Main image click → open at current index ──────────────────
        mainImage.addEventListener('click', () => {
            const idx = parseInt(mainImage.getAttribute('data-index') || '0', 10);
            openLightbox(idx);
        });

        // ── Controls ──────────────────────────────────────────────────
        lbClose?.addEventListener('click', closeLightbox);
        lbPrev?.addEventListener('click',  () => showImage(currentIndex - 1));
        lbNext?.addEventListener('click',  () => showImage(currentIndex + 1));

        // Click outside image closes lightbox
        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });

        // Keyboard support
        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('is-open')) return;
            if (e.key === 'Escape')      closeLightbox();
            if (e.key === 'ArrowLeft')   showImage(currentIndex - 1);
            if (e.key === 'ArrowRight')  showImage(currentIndex + 1);
        });
    });
</script>
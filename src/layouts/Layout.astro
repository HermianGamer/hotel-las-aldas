---
import '../styles/global.css'

import '@fontsource/poppins/400.css'
import '@fontsource/poppins/500.css'
import '@fontsource/poppins/600.css'
import '@fontsource/poppins/700.css'
import '@fontsource/poppins/800.css'
import '@fontsource/poppins/900.css'

interface Props{
	title?: string;
	description?: string;
	isHomePage?: boolean;
}

import Header from '../components/Header';
import Footer from '@/components/Footer.astro'

const { 
	title = 'Hotel Las Aldas',
	description='El Hotel Las Aldas se alza frente al mar de Áncash como un refugio de calma y sobriedad, donde el tiempo parece transcurrir con otra cadencia. Un espacio pensado para quienes valoran el descanso, la contemplación y la belleza serena del litoral peruano.',
	isHomePage = false
} = Astro.props;
---

<script is:inline>
    const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };
    const isDark = getThemePreference() === 'dark';
    document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

    if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }
</script>

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>

	<body class="font-poppins">
		<Header client:load isHomePage={isHomePage} />

		<slot />

		<Footer />
	</body>
</html>
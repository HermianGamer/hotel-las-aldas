---
import '../styles/global.css'

import '@fontsource/playwrite-pe/400.css';

import '@fontsource/libre-baskerville/400.css'
import '@fontsource/libre-baskerville/700.css'

interface Props{
	title?: string;
	description?: string;
	isHomePage?: boolean;
	image?: string;
	noindex?: boolean;
	schema?: object | object[];
}

import Footer from '@/components/Footer.astro'
import ClerkWrapper from "../components/ClerkWrapper";
import ToastProvider from '@/components/ToastProvider'
import { SITE_URL, SITE_NAME, DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE, buildHotelSchema } from '@/lib/seo';

const {
	title,
	description = DEFAULT_DESCRIPTION,
	isHomePage = false,
	image = DEFAULT_OG_IMAGE,
	noindex = false,
	schema,
} = Astro.props;

const pageTitle = isHomePage || !title
	? `${SITE_NAME} | Hotel Frente al Mar en Áncash, Perú`
	: `${title} | ${SITE_NAME} – Áncash, Perú`;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();

const structuredData = isHomePage
	? [buildHotelSchema(), ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])]
	: (schema ? (Array.isArray(schema) ? schema : [schema]) : []);
---

<script is:inline>
    const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };
    const isDark = getThemePreference() === 'dark';
    document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

    if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }
</script>

<!doctype html>
<html lang="es-PE">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" type="image/x-icon" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<title>{pageTitle}</title>

		<!-- Open Graph -->
		<meta property="og:type" content={isHomePage ? 'website' : 'article'} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="es_PE" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		{structuredData.map((entry) => (
			<script type="application/ld+json" set:html={JSON.stringify(entry)} />
		))}
	</head>

	<body class="font-family">

		<ClerkWrapper
			client:idle
			publishableKey={import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY}
			isHomePage={isHomePage}
		/>

		<slot />

		<Footer />
		<ToastProvider client:load />
	</body>
</html>
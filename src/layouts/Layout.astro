---
import '../styles/global.css'

import '@fontsource/playwrite-pe/400.css';

import '@fontsource/libre-baskerville/400.css'
import '@fontsource/libre-baskerville/700.css'

interface Props{
	title?: string;
	description?: string;
	isHomePage?: boolean;
}

import Footer from '@/components/Footer.astro'
import ClerkWrapper from "../components/ClerkWrapper";
import ToastProvider from '@/components/ToastProvider'


const { 
	title = 'Hotel Las Aldas',
	description='El Hotel Las Aldas se alza frente al mar de Áncash como un refugio de calma y sobriedad, donde el tiempo parece transcurrir con otra cadencia. Un espacio pensado para quienes valoran el descanso, la contemplación y la belleza serena del litoral peruano.',
	isHomePage = false
} = Astro.props;
---

<script is:inline>
    const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };
    const isDark = getThemePreference() === 'dark';
    document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

    if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }
</script>

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" type="image/x-icon" />
		<link rel="canonical" href="https://lasaldas.com/" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>

	<body class="font-family">

		<ClerkWrapper
			client:idle
			publishableKey={import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY}
			isHomePage={isHomePage}
		/>

		<slot />

		<Footer />
		<ToastProvider client:load />
	</body>
</html>
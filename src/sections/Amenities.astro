---
import AmenitiesCard from "@/components/AmenitiesCard.astro";
import chankilloThumb from "@/assets/thumbnails/chankillo-thumb.jpg";
import matrimonioThumb from "@/assets/thumbnails/matrimonio-thumb.jpg";
import huaroThumb from "@/assets/thumbnails/huaro-thumb.jpg";
import aldasThumb from "@/assets/thumbnails/aldas-thumb.jpg";
---


<section class="pt-28" id="experiences">
    <div class="container ">
        <div class="mx-auto text-center mb-8">
            <h2 class="mb-1 text-500 font-600 md:text-600">Experiencias en el Hotel y Alrededores</h2>
        </div>

        <div class="space-y-6 md:space-y-0 md:grid md:grid-cols-2 md:gap-12 lg:grid-cols-4 items-center">
            <AmenitiesCard name="Chankillo" alt="Observatorio solar de Chankillo, cerca de Hotel Las Aldas en Áncash" image={chankilloThumb} url='/experiences/chankillo'/>
            <AmenitiesCard name="Matrimonios" alt="Matrimonios frente al mar en Hotel Las Aldas, Áncash" image={matrimonioThumb} url='/experiences/matrimonio'/>
            <AmenitiesCard name="El Huaro" alt="Playa de la Ruta El Huaro y avistamiento de lobos marinos, Áncash" image={huaroThumb} url='/experiences/huaro'/>
            <AmenitiesCard name="Las Aldas (Ruinas)" alt="Complejo arqueológico Las Aldas frente al mar, Áncash" image={aldasThumb} url='/experiences/aldas'/>
        </div>

        <div class="text-center mt-8">
            <a href="/destinos" class="underline underline-offset-2 hover:text-primary">Ver todas las playas y destinos cerca de Áncash</a>
        </div>
    </div>
</section>
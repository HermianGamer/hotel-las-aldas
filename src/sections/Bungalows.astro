---
import BungalowCard from '@/components/BungalowCard.astro'
import suitesThumb from '@/assets/thumbnails/suites-thumb.jpg'
import standardThumb from '@/assets/thumbnails/standard-thumb.jpg'
import allThumb from '@/assets/thumbnails/all-thumb.jpg'
---



<section class="pt-28">
    <div class="container ">
        <div class="mc-auto text-center ">
            <h2 class="mb-1 text-500 font-600 md:text-600">Categorías de Bungalows</h2>
        </div>

        <div class="md:grid md:gap-9 md:grid-cols-2 lg:grid-cols-3">
            <BungalowCard name="Suites" image={suitesThumb} url="/suites" alt="Bungalows Suite frente al mar en Hotel Las Aldas, Áncash" />
            <BungalowCard name="Standard" image={standardThumb} url="/standard" alt="Bungalows Standard en Hotel Las Aldas, Áncash" />
            <BungalowCard name="Todos" image={allThumb} url="/all" alt="Todos los bungalows de Hotel Las Aldas, Áncash" />
        </div>
    </div>
</section>
---
import { RiNumber1 } from "react-icons/ri";
---

<section class="bg-muted mt-28">
    <div class="container py-16">
        <div class="lg:grid lg:grid-cols-2 lg:items-center lg:gap-12 grid gap-4">
            <!-- Explicacion -->
            <div>
                <h2 class="text-500 md:text-600 mb-1 font-600">Ubícanos</h2>

                <ul class="mt-6 space-y-4 md:space-y-20">

                    <li class="flex items-start">
                        <div class="w-6 text-background bg-primary mr-3 flex items-center justify-center rounded-full aspect-square">
                            <RiNumber1 />
                        </div>
                        <div>
                            <h3 class="font-medium">Llegar al Km. 347 de la Panamericana Norte</h3>
                        </div>
                    </li>

                    <li class="flex items-start">
                        <div class="text-primary bg-primary mr-3 flex items-center justify-center rounded-full aspect-square">
                            -<span class="text-white">2</span>-
                        </div>
                        <div>
                            <h3 class="font-medium">Entrada por el restaurante "La Balsa"</h3>
                        </div>
                    </li>

                    <li class="flex items-start">
                        <div class="text-primary bg-primary mr-3 flex items-center justify-center rounded-full aspect-square">
                            -<span class="text-white">3</span>-
                        </div>
                        <div>
                            <h3 class="font-medium">Tomar la segunda salida a la derecha</h3>
                        </div>
                    </li>

                </ul>
            </div>

            <!-- Ubicacion -->
             <div class="h-full">
                <iframe class="h-full w-full"
                 src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6071.244046216509!2d-78.29556111730497!3d-9.710145323575457!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f30.1!3m3!1m2!1s0x91aa4aa7eea1ceb3%3A0x9a393b86dbe79812!2sHotel%20Las%20Aldas!5e0!3m2!1sen!2spe!4v1768106889382!5m2!1sen!2spe" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                </iframe>
             </div>
        </div>
    </div>
</section>
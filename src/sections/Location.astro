---
import { Image } from "astro:assets";
import mapa from "@/assets/mapa.jpg";
---


<section class="bg-foreground mt-28" id="ubicanos">
    <div class="container py-16">
        <div class="lg:grid lg:grid-cols-2 lg:items-center lg:gap-12 grid gap-4 text-background">
            <!-- Explicacion -->
            <div>
                <h2 class="text-500 md:text-600 mb-1 font-600">Ubícanos</h2>

                <address class="not-italic mt-2 text-background/80">
                    Km. 347 Panamericana Norte, Caleta La Gramita — Casma, Áncash, Perú<br />
                    Tel / WhatsApp: <a href="https://wa.me/51923381810" target="_blank" class="hover:text-background underline underline-offset-2">+51 923 381 810</a>
                </address>

                <ol class="mt-6 space-y-4 md:space-y-20">

                    <li class="flex items-start">
                        <span aria-hidden="true" class="w-6 font-600 aspect-square block">1.</span>
                        <p class="font-medium">Llegar al Km. 347 de la Panamericana Norte</p>
                    </li>

                    <li class="flex items-start">
                        <span aria-hidden="true" class="w-6 font-600 aspect-square block">2.</span>
                        <p class="font-medium">Entrada por el restaurante "La Balsa"</p>
                    </li>

                    <li class="flex items-start">
                        <span aria-hidden="true" class="w-6 font-600 aspect-square block">3.</span>
                        <p class="font-medium">Tomar la segunda salida a la derecha</p>
                    </li>

                </ol>
            </div>

            <!-- Ubicacion -->
             <div class="h-full">
                <a
                href="https://maps.app.goo.gl/qD5mpfQqtWZSL2Kq5"
                target="_blank"
                aria-label="Ver Hotel Las Aldas en Google Maps"
                >
                    <Image
                        class="h-full w-full object-cover cursor-help transition-transform duration-300 ease-in-out hover:scale-105"
                        src={mapa}
                        width={900}
                        height={600}
                        loading="lazy"
                        decoding="async"
                        alt="Ubicación Hotel Las Aldas en Google Maps"
                    />
                </a>
             </div>
        </div>
    </div>
</section>
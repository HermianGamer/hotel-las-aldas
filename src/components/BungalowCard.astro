---
import { Image } from 'astro:assets';

const {name, image, url} = Astro.props;
---

<div class="group p-8 md:mb-0 overflow-visible">

    <!-- Image -->
    <div class="relative h-65 flex items-center justify-center overflow-visible">
        <a class="block" href={url}>
            <Image src={image}
            alt={name}
            class="max-h-full max-w-full transition-all duration-300 ease-in-out group-hover:scale-110 group-hover:drop-shadow-[7px_7px_0_rgba(177,146,112,0.85)] dark:group-hover:drop-shadow-[7px_7px_0_rgba(177,146,112,0.85)]"
            />
        </a>

    </div>



        {/* Name*/}
    <div class="relative p-4">
        <a href={url}>
        <h2 class="z-20 text-200 font-500 text-center duration-150 group-hover:opacity-0 p-1" style="filter: none;">
            {name}
        </h2>
        </a>
    </div> 
</div>

---
import { Button } from "./ui/button.tsx";
import { Image } from "astro:assets";
import Libro from "../assets/reclamaciones.png";
---


<footer class="bg-foreground relative mt-56 pt-28 pb-8 text-background dark:text-background">
    <div class="container">
        <div class="md:grid md:grid-cols-2 md:gap-4 lg:mb-8 lg:grid-cols-3">

            <!-- Col. 1: Description -->
            <div class="mb-8 md:mb-0">
                <h3 class="uppercase text-300 font-500 mb-2">Las Aldas</h3>

                <p class="mb-6">El Hotel Las Aldas se alza frente al mar Casmeño como un refugio de calma.
                    Un espacio para quienes valoran el descanso, la contemplación y la belleza del litoral peruano.
                </p>

                <p class="mb-6">Contacto por correo: info@lasaldas.com
                </p>

                <a href="/all" class="hover:text-primary transition-colors duration-300 ease-in-out">
                    <Button variant="default" className="uppercase font-600">Reservar</Button>
                </a>
        </div>

            <!-- Col. 2: Quick Menu -->
            <div class="mb-8 md:mb-0 md:justify-self-end lg:translate-x-12">
                <h3 class="uppercase text-300 font-500 mb-2">Menú</h3>
                <ul class="list-none">
                    <li class="mb-2">
                        <a href="/all" class="hover:text-primary transitions-colors duration-300 ease">Bungalows</a>
                    </li>
                    <li class="mb-2">
                        <a href="/#experiences" class="hover:text-primary transitions-colors duration-300 ease">Experiencias</a>
                    </li>
                    <li>
                        <a href="https://wa.me/51923381810" target="_blank" class="hover:text-primary transitions-colors duration-300 ease">Contacto</a>
                    </li>
                </ul>
            </div>

            <!-- Col. 3: Other Links -->
            <div class="mb-8 md:mb-0 lg:justify-self-center lg:translate-x-12">
                <h3 class="uppercase text-300 font-500 mb-2">Más Enlaces</h3>
                <ul class="list-none">
                    <li class="mb-2">
                        <a href="/complaint" class="flex items-center gap-2 hover:text-primary transitions-colors duration-300 ease">
                            <Image src={Libro} class="h-8 w-13" alt="reclamaciones"/>
                            <p>Libro de Reclamaciones</p>
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/terms" class="hover:text-primary transitions-colors duration-300 ease">Términos y condiciones</a>
                    </li>
                    <li class="mb-2">
                        <a href="/policies" class="hover:text-primary transitions-colors duration-300 ease">Política de cambios y/o devoluciones</a>
                    </li>
                    <li>
                        <a href="/about" class="hover:text-primary transitions-colors duration-300 ease">Sobre Nosotros</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="pt-12 text-center">
            <p>© {new Date().getFullYear() } Hotel Las Aldas E.I.R.L. Todos los derechos reservados</p>
        </div>
    </div>
</footer>
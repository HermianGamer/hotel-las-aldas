---
import { Button } from "./ui/button.tsx";

import { FaInstagram, FaSquareFacebook, FaSquareTwitter, FaTiktok } from "react-icons/fa6";
---


<footer class="bg-foreground relative mt-56 pt-28 pb-8 text-background dark:text-background">
    <div class="container">
        <div class="md:grid md:grid-cols-2 md:gap-4 lg:mb-8 lg:grid-cols-3">

            <!-- Col. 1: Description -->
            <div class="mb-8 md:mb-0">
                <h3 class="uppercase text-300 font-500 mb-2">Las Aldas</h3>

                <div class="flex mb-2 gap-6 md:gap-2">
                    <a href="https://www.instagram.com/hotel_las_aldas/" target="_blank"> <FaInstagram />     </a>
                    <a href="https://www.facebook.com/HotelLasAldas/" target="_blank">    <FaSquareFacebook/> </a>
                    <a href="https://x.com/HotelLasAldas" target="_blank">                <FaSquareTwitter/>  </a>
                    <a href="https://www.tiktok.com/@hotel_las_aldas" target="_blank">    <FaTiktok/>         </a>
                </div>

                <a href="/all" class="hover:text-primary transition-colors duration-300 ease-in-out">
                    <Button variant="secondary" className="uppercase font-600">Reservar</Button>
                </a>
            </div>

            <!-- Col. 2: Quick Menu -->
            <div class="mb-8 md:mb-0 md:justify-self-end lg:translate-x-12">
                <h3 class="uppercase text-300 font-500 mb-2">Menú</h3>
                <ul class="list-none">
                    <li class="mb-2">
                        <a href="/all" class="hover:text-background/50 transitions-colors duration-300 ease">Bungalows</a>
                    </li>
                    <li class="mb-2">
                        <a href="/#experiences" class="hover:text-background/50 transitions-colors duration-300 ease">Experiencias</a>
                    </li>
                    <li>
                        <a href="https://wa.me/51923381810" target="_blank" class="hover:text-background/50 transitions-colors duration-300 ease">Contacto</a>
                    </li>
                </ul>
            </div>

            <!-- Col. 3: Other Links -->
            <div class="mb-8 md:mb-0 lg:justify-self-center lg:translate-x-12">
                <h3 class="uppercase text-300 font-500 mb-2">Más Enlaces</h3>
                <ul class="list-none">
                    <li class="mb-2">
                        <a href="/complaint" class="flex items-center gap-2 hover:text-background/50 transitions-colors duration-300 ease">
                            <img src='/assets/reclamaciones.png' class="h-8 w-13" alt="reclamaciones"/>
                            <p>Libro de Reclamaciones</p>
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/terms" class="hover:text-background/50 transitions-colors duration-300 ease">Términos y condiciones</a>
                    </li>
                    <li class="mb-2">
                        <a href="/policies" class="hover:text-background/50 transitions-colors duration-300 ease">Política de cambios y/o devoluciones</a>
                    </li>
                    <li class="mb-2">
                        <a href="https://compactdisc.pixieset.com/hotellasaldas/recepcion/" target="_blank" class="hover:text-background/50 transitions-colors duration-300 ease">Galería</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="pt-12 text-center">
            <p>© {new Date().getFullYear() } Hotel Las Aldas E.I.R.L. Todos los derechos reservados</p>
        </div>
    </div>
</footer>
---
import { Button } from "./ui/button.tsx"
---


<footer class="bg-foreground relative mt-28 pt-20 pb-8 text-background dark:text-background">
    <div class="container">
        <div class="md:grid md:grid-cols-2 md:gap-4 lg:mb-8 lg:grid-cols-3">

            <!-- Col. 1: Description -->
            <div class="mb-8 md:mb-0">
                <h3 class="uppercase text-300 font-500 mb-2">Las Aldas</h3>

                <p class="mb-6">El Hotel Las Aldas se alza frente al mar Casmeño como un refugio de calma. 
                    Un espacio para quienes valoran el descanso, la contemplación y la belleza del litoral peruano.
                </p>

                <a href="/all" class="hover:text-primary transition-colors duration-300 ease-in-out">
                    <Button variant="outline" className="uppercase font-600 dark:border-primary dark:hover:bg-primary dark:hover:text-foreground">Reservar</Button>
                </a>
            </div>

            <!-- Col. 2: Quick Menu -->
            <div class="mb-8 md:mb-0 md:justify-self-end lg:translate-x-[3rem]">
                <h3 class="uppercase text-300 font-500 mb-2">Menú</h3>
                <li class="mb-2 list-none">
                    <a href="/all" class="hover:text-primary transitions-colors duration-300 ease">Bungalows</a></li>
                <li class="mb-2 list-none">
                    <a href="/#experiences" class="hover:text-primary transitions-colors duration-300 ease">Experiencias</a></li>
                <li class="list-none">
                    <a href="https://wa.me/51923381810" target="_blank" class="hover:text-primary transitions-colors duration-300 ease">Contacto</a></li>
            </div>

            <!-- Col. 3: Other Links -->
            <div class="mb-8 md:mb-0 lg:justify-self-center lg:translate-x-[3rem]">
                <h3 class="uppercase text-300 font-500 mb-2">Más Enlaces</h3>
                <li class="mb-2 list-none">
                    <a href="https://wa.me/51923381810?text=Hola,%20me%20interesa%20más%20información" target="_blank" target="_blank" class="hover:text-primary transitions-colors duration-300 ease">Libro de Reclamaciones</a></li>
                <li class="mb-2 list-none">
                    <a href="/policies" class="hover:text-primary transitions-colors duration-300 ease">Políticas</a></li>
                <li class="list-none">
                    <a href="/about" class="hover:text-primary transitions-colors duration-300 ease">Sobre Nosotros</a></li>
            </div>
        </div>

        <div class="pt-12 text-center">
            <p>© {new Date().getFullYear() } Hotel Las Aldas E.I.R.L. Todos los derechos reservados</p>
        </div>
    </div>
</footer>
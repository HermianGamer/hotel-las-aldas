---
import { Image } from 'astro:assets';

const { name, image, url } = Astro.props;
---

<div class="group relative mb-8 overflow-hidden rounded-lg md:mb-0 h-full w-full">
    <a href={url}>
        <div class="absolute inset-0 z-10 h-full w-full bg-black opacity-25 transition-opacity duration-300 ease-in-out group-hover:opacity-45">
        </div>

        <Image src={image} alt={name} class="rounded-lg h-full w-full transition-transform duration-300 ease-in-out group-hover:scale-105" />
        <p class="absolute bottom-4 left-4 z-20 text-200 font-500 text-white transition-all duration-300 group-hocver:bottom-6">{name}</p>
    </a>
</div>
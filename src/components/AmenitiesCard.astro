---
const { name, image, url } = Astro.props;
---
<div class="group relative mb-8 overflow-hidden md:mb-0 h-full w-full">
    <a href={url}>
        <div class="absolute inset-0 z-10 h-full w-full transition-opacity duration-200 ease-in-out group-hover:opacity-75">
        </div>
        <img 
            src={image} 
            alt={name} 
            width={332}
            height={221}
            loading="lazy"
            class="h-full w-full transition-transform duration-300 ease-in-out group-hover:scale-105" 
        />
        <p class="absolute bottom-4 left-4 z-20 text-200 font-500 text-background dark:text-foreground transition-all duration-300 group-hover:bottom-6">{name}</p>
    </a>
</div>